---
import BaseLayout from '../layouts/BaseLayout.astro';

// Auto-discovers every file in public/stamps/ at build time.
const stampModules = import.meta.glob('/public/stamps/*');
const stamps = Object.keys(stampModules).map(path => path.replace('/public', ''));

// The seamless loop works by animating translateX(-50%) across a set rendered twice.
// That only works if one set is wider than the visible bar (~1300px).
// So we pad the array up to at least 30 entries before doubling it.
const MIN_STAMPS = 30;
const copies = Math.ceil(MIN_STAMPS / stamps.length);
const paddedStamps = Array(copies).fill(stamps).flat();
---

<BaseLayout title="Oliver Ohrt">
  <div class="layout">
    <div class="box header">
      <div class="logo-wrap">
        <img class="logo-fallback" src="/images/logo_fallback.png" width="823" height="287" alt="Oliver Ohrt logo" />
        <div class="logo-composite">
          <img src="/images/gears.webp" width="169" height="287" alt=""
            onload="this.closest('.logo-wrap').querySelector('.logo-fallback').style.display='none'" />
          <img src="/images/static.png" width="654" height="287" alt="" />
        </div>
      </div>
    </div>

    <div class="box subheader">
      <div class="welcome-scroll">
        <span>Welcome to my site!</span>
      </div>
    </div>
    <div class="box subheader stamps">
      <div class="marquee" aria-label="Stamp collection">
        <div class="marquee__inner">
          {paddedStamps.map(src => <img src={src} alt="" fetchpriority="low" />)}
        </div>
        <div class="marquee__inner" aria-hidden="true">
          {paddedStamps.map(src => <img src={src} alt="" fetchpriority="low" />)}
        </div>
      </div>
      <script>
        const marquee = document.querySelector('.marquee') as HTMLElement;
        if (marquee) {
          const imgs = marquee.querySelectorAll('img');
          let loaded = 0;
          const check = () => { if (++loaded >= imgs.length) marquee.classList.add('is-ready'); };
          imgs.forEach(img => img.complete ? check() : (img.onload = img.onerror = check));
        }
      </script>
    </div>
  </div>
</BaseLayout>

<style>
  .header {
    height: 288px;
    position: relative;
    width: 134.5%;
    left: -17.2%;
    overflow: visible;
    background: #597997 url('/images/header.png') center/cover no-repeat;
  }

  .logo-wrap {
    position: absolute;
    left: -90px;
    top: 5px;
    z-index: 999;
  }

  .logo-fallback {
    display: block;
  }

  .logo-composite {
    position: absolute;
    top: 0;
    left: 0;
    display: flex;
  }

  .subheader {
    height: 30px;
    position: relative;
    width: 134.5%;
    left: -17.2%;
    background: linear-gradient(to bottom, #BDD3F4 0%, #92AEED 50%, #597997 51%, #A8BEFF 100%);
  }

  .welcome-scroll {
    display: flex;
    overflow: hidden;
    height: 100%;
    align-items: center;
  }

  .welcome-scroll span {
    display: inline-block;
    white-space: nowrap;
    padding-left: 100%;
    animation: welcome-scroll 12s linear infinite;
    color: rgb(3, 48, 252);
    text-shadow: 0 0 6px #ffffff, 0 0 10px #ffffff;
    font-weight: bold;
    font-size: 14px;
  }

  @keyframes welcome-scroll {
    from { transform: translateX(-100%); }
    to   { transform: translateX(100%); }
  }

  /* Stamp marquee bar */
  .stamps {
    height: 60px;
    background: linear-gradient(to bottom, #F4EFBD 0%, #EDEA92 50%, #979259 51%, #FFFFA8 100%);
  }

  .marquee {
    contain: layout paint;
    display: flex;
    overflow: hidden;
    height: 100%;
  }

  .marquee__inner {
    display: flex;
    flex-shrink: 0;
    align-items: center;
    gap: 4px;
    min-width: 100%;
    will-change: transform;
    animation: stamp-scroll 35s linear infinite;
    animation-play-state: paused;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .marquee.is-ready .marquee__inner {
    animation-play-state: running;
    opacity: 1;
  }

  .marquee__inner img {
    flex-shrink: 0;
    height: 52px;
    width: auto;
  }

  @keyframes stamp-scroll {
    to { transform: translateX(calc(-100% - 4px)); }
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee__inner {
      animation-play-state: paused !important;
      opacity: 1 !important;
    }
    .welcome-scroll span {
      animation-play-state: paused !important;
    }
  }

  /* ── Mobile overrides ─────────────────────────────────────────────────────
     The whole layout is scaled down via transform in BaseLayout.
     These values are in the *unscaled* coordinate space, the browser scales
     them along with everything else.

     Logo: left: -90px sits at -255px in layout coords (header is at -165px).
     Setting left: 110px brings the logo onto screen after scaling.

     Heights doubled so they appear the same relative size after scaling.
  ───────────────────────────────────────────────────────────────────────── */
  @media (max-width: 1020px) {
    .header,
    .subheader {
      width: 100%;
      left: 0;
    }

    .logo-wrap {
      left: -55px;
    }

    .subheader:not(.stamps) {
      height: 60px;
    }

    .stamps {
      height: 120px;
    }

    .marquee {
      height: 120px;
    }

    .marquee__inner img {
      height: 104px;
    }

    .welcome-scroll span {
      font-size: 28px;
    }
  }
</style>
