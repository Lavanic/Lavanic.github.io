---
import BaseLayout from '../layouts/BaseLayout.astro';

// Auto-discovers every file in public/stamps/ at build time.
const stampModules = import.meta.glob('/public/stamps/*');
const stamps = Object.keys(stampModules).map(path => path.replace('/public', ''));

// The seamless loop works by animating translateX(-50%) across a set rendered twice.
// That only works if one set is wider than the visible bar (~1300px).
// So we pad the array up to at least 30 entries before doubling it.
const MIN_STAMPS = 30;
const copies = Math.ceil(MIN_STAMPS / stamps.length);
const paddedStamps = Array(copies).fill(stamps).flat();
---

<BaseLayout title="Oliver Ohrt">
  <div class="layout">
    <div class="box header">
      <div class="logo-wrap">
        <img class="logo-fallback" src="/images/logo_fallback.png" width="823" height="287" alt="Oliver Ohrt logo" />
        <div class="logo-composite">
          <!-- gears.webp is 2MB — skip it on mobile to avoid slow loads. -->
          <img id="gears-img" src="" data-src="/images/gears.webp" width="169" height="287" alt=""
            onload="this.closest('.logo-wrap').querySelector('.logo-fallback').style.display='none'" />
          <img src="/images/static.png" width="654" height="287" alt="" />
        </div>
      </div>
    </div>
    <script>
      // Only load the 2MB animated gears on desktop
      // static fallback PNG which is already loaded and looks the same.
      if (window.innerWidth > 1020) {
        const img = document.getElementById('gears-img') as HTMLImageElement | null;
        if (img) img.src = img.dataset.src!;
      }
    </script>

    <div class="box subheader">
      <marquee behavior="scroll" direction="right" style="color:rgb(3, 48, 252); text-shadow: 0 0 6px #ffffff, 0 0 10px #ffffff; font-weight: bold; font-size: 14px;">
        Welcome to my site!
      </marquee>
    </div>
    <div class="box subheader stamps">
      <div class="marquee">
        <div class="marquee__inner">
          <!-- paddedStamps is the base set (repeated until ≥30 entries so it
               overflows the bar). Rendered twice total so the -50% trick loops
               seamlessly — at -50% you're exactly back to where you started. -->
          {paddedStamps.map(src => <img src={src} alt="" loading="lazy" decoding="async" />)}
          {paddedStamps.map(src => <img src={src} alt="" loading="lazy" decoding="async" />)}
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .header {
    height: 288px;
    position: relative;
    width: 134.5%;
    left: -17.2%;
    overflow: visible;
    background: #597997;
  }

  .logo-wrap {
    position: absolute;
    left: -90px;
    top: 5px;
    z-index: 999;
  }

  .logo-fallback {
    display: block;
  }

  .logo-composite {
    position: absolute;
    top: 0;
    left: 0;
    display: flex;
  }

  .subheader {
    height: 30px;
    position: relative;
    width: 134.5%;
    left: -17.2%;
    background: linear-gradient(to bottom, #BDD3F4 0%, #92AEED 50%, #597997 51%, #A8BEFF 100%);
  }

  /* Stamp marquee bar */
  .stamps {
    height: 60px;
    background: linear-gradient(to bottom, #F4EFBD 0%, #EDEA92 50%, #979259 51%, #FFFFA8 100%);
  }

  .marquee {
    display: flex;
    overflow: hidden;
    height: 100%;
    align-items: center;
  }

  .marquee__inner {
    display: flex;
    flex-shrink: 0;
    animation: stamp-scroll 35s linear infinite;
  }

  .marquee__inner img {
    flex-shrink: 0;
    margin: 2px;
    height: 52px;
    width: auto;
  }

  @keyframes stamp-scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* ── Mobile overrides ─────────────────────────────────────────────────────
     The whole layout is scaled down via transform in BaseLayout.
     These values are in the *unscaled* coordinate space, the browser scales
     them along with everything else.

     Logo: left: -90px sits at -255px in layout coords (header is at -165px).
     Setting left: 165px cancels the header's -165px, landing the logo right
     at the layout's left edge (~10px from viewport at 375px / scale 0.37).

     Heights doubled so they appear the same relative size after scaling.
     Font-size doubled; needs !important to beat the inline style.
  ───────────────────────────────────────────────────────────────────────── */
  @media (max-width: 1020px) {
    .logo-wrap {
      left: 110px;
    }

    .subheader:not(.stamps) {
      height: 60px;
    }

    .stamps {
      height: 120px;
    }

    .marquee__inner img {
      height: 104px;
    }

    .subheader:not(.stamps) marquee {
      font-size: 28px !important;
      line-height: 60px;
    }
  }
</style>
