---
import BaseLayout from '../layouts/BaseLayout.astro';

// Auto-discovers every file in public/stamps/ at build time.
const stampModules = import.meta.glob('/public/stamps/*');
const stamps = Object.keys(stampModules).map(path => path.replace('/public', ''));

// The seamless loop works by animating translateX(-50%) across a set rendered twice.
// That only works if one set is wider than the visible bar (~1300px).
// So we pad the array up to at least 30 entries before doubling it.
const MIN_STAMPS = 30;
const copies = Math.ceil(MIN_STAMPS / stamps.length);
const paddedStamps = Array(copies).fill(stamps).flat();
---

<BaseLayout title="Oliver Ohrt">
  <div class="layout">
    <div class="box header">
      <div class="logo-wrap">
        <img class="logo-fallback" src="/images/logo_fallback.png" width="823" height="287" alt="Oliver Ohrt logo" />
        <div class="logo-composite">
          <img src="/images/gears.webp" width="169" height="287" alt=""
            onload="var w=this.closest('.logo-wrap');w.querySelector('.logo-fallback').style.display='none';w.querySelector('.logo-composite').style.opacity='1'" />
          <img src="/images/static.png" width="654" height="287" alt="" />
        </div>
      </div>
    </div>

    <div class="box subheader">
      <div class="welcome-scroll">
        <span>Welcome to my site!</span>
      </div>
    </div>
    <div class="box subheader stamps">
      <div class="marquee" aria-label="Stamp collection">
        <div class="marquee__inner">
          {paddedStamps.map(src => <img src={src} alt="" fetchpriority="low" />)}
        </div>
        <div class="marquee__inner" aria-hidden="true">
          {paddedStamps.map(src => <img src={src} alt="" fetchpriority="low" />)}
        </div>
      </div>
      <script>
        const marquee = document.querySelector('.marquee') as HTMLElement;
        if (marquee) {
          const imgs = marquee.querySelectorAll('img');
          let loaded = 0;
          const check = () => { if (++loaded >= imgs.length) marquee.classList.add('is-ready'); };
          imgs.forEach(img => img.complete ? check() : (img.onload = img.onerror = check));
        }
      </script>
    </div>

    <div class="row main-row">
      <aside class="box panel panel-left"></aside>
      <main class="box panel panel-center">
        <div class="panel-content">
          <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.</p>
          <p>Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur. Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia deserunt mollit anim id est laborum.</p>
          <p>Curabitur pretium tincidunt lacus. Nulla gravida orci a odio. Nullam varius, turpis et commodo pharetra, est eros bibendum elit, nec luctus magna felis sollicitudin mauris. Integer in mauris eu nibh euismod gravida.</p>
          <p>Duis ac tellus et risus vulputate vehicula. Donec lobortis risus a elit. Etiam tempor. Ut ullamcorper, ligula eu tempor congue, eros est euismod turpis, id tincidunt sapien risus a quam.</p>
          <p>Maecenas fermentum consequat mi. Donec fermentum. Pellentesque malesuada nulla a mi. Duis sapien sem, aliquet nec, commodo eget, consequat quis, neque. Aliquam faucibus, elit ut dictum aliquet, felis nisl adipiscing sapien.</p>
          <p>Sed velit. Sed nec mi vel justo congue luctus. Aliquam erat volutpat. Sed quis velit. Nulla facilisi. Nulla libero. Vivamus pharetra posuere sapien. Nam consectetuer. Sed aliquam, nunc eget euismod ullamcorper, lectus nunc ullamcorper orci.</p>
          <p>Quisque eget odio ac lectus vestibulum faucibus eget in metus. In pellentesque faucibus vestibulum. Nulla at nulla justo, eget luctus tortor. Nulla facilisi. Duis aliquet egestas purus in blandit.</p>
          <p>Curabitur vulputate, ligula lacinia scelerisque tempor, lacus lacus ornare ante, ac egestas est urna sit amet arcu. Class aptent taciti sociosqu ad litora torquent per conubia nostra, per inceptos himenaeos. Sed molestie augue sit amet leo consequat posuere.</p>
        </div>
      </main>
      <aside class="box panel panel-right no-mobile"></aside>
    </div>
  </div>
</BaseLayout>

<style>
  .header {
    height: 288px;
    position: relative;
    width: 134.5%;
    left: -17.2%;
    overflow: visible;
    flex-shrink: 0;
    background: #3A7AB6 url('/images/header.png') center/cover no-repeat;
  }

  .logo-wrap {
    position: absolute;
    left: -90px;
    top: 5px;
    z-index: 999;
  }

  .logo-fallback {
    display: block;
  }

  .logo-composite {
    position: absolute;
    top: 0;
    left: 0;
    display: flex;
    opacity: 0;
    transition: opacity 0.15s ease;
  }

  .subheader {
    height: 30px;
    position: relative;
    width: 134.5%;
    left: -17.2%;
    flex-shrink: 0;
    background: linear-gradient(to bottom, #B2D1FF 0%, #80A7FF 50%, #3A7AB6 51%, #A8BEFF 100%);
  }

  .welcome-scroll {
    display: flex;
    overflow: hidden;
    height: 100%;
    align-items: center;
  }

  .welcome-scroll span {
    display: inline-block;
    white-space: nowrap;
    padding-left: 100%;
    animation: welcome-scroll 12s linear infinite;
    color: rgb(0, 46, 255);
    text-shadow: 0 0 6px #ffffff, 0 0 10px #ffffff;
    font-weight: bold;
    font-size: 14px;
  }

  @keyframes welcome-scroll {
    from { transform: translateX(-100%); }
    to   { transform: translateX(100%); }
  }

  /* Stamp marquee bar */
  .stamps {
    height: 60px;
    background: linear-gradient(to bottom, #FFF8B2 0%, #FFFB80 50%, #C2B41A 51%, #FFFFA8 100%);
  }

  .marquee {
    contain: layout paint;
    display: flex;
    overflow: hidden;
    height: 100%;
  }

  .marquee__inner {
    display: flex;
    flex-shrink: 0;
    align-items: center;
    gap: 4px;
    min-width: 100%;
    will-change: transform;
    animation: stamp-scroll 35s linear infinite;
    animation-play-state: paused;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .marquee.is-ready .marquee__inner {
    animation-play-state: running;
    opacity: 1;
  }

  .marquee__inner img {
    flex-shrink: 0;
    height: 52px;
    width: auto;
  }

  @keyframes stamp-scroll {
    to { transform: translateX(calc(-100% - 4px)); }
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee__inner {
      animation-play-state: paused !important;
      opacity: 1 !important;
    }
    .welcome-scroll span {
      animation-play-state: paused !important;
    }
  }

  /* Row of three panels below the stamp bar.*/
  .main-row {
    display: flex;
    gap: var(--gap);
    position: relative;
    width: 140%;
    left: -20%;
    min-height: 620px;
    flex-shrink: 0;
  }

  .panel-left   { flex: 0 0 17%; }
  .panel-center { flex: 1 1 auto; display: flex; flex-direction: column; padding: 30px; }
  .panel-right  { flex: 0 0 20%; }

  .panel-content {
    flex: 1 1 0;
    min-height: 0;
    overflow-y: auto;
    background: #3F6589;
    color: #fff;
    padding: 18px;
    font-size: 15px;
    line-height: 1.55;
  }

  .panel-content p + p {
    margin-top: 12px;
  }

  /* Gradient*/
  .panel {
    background: linear-gradient(
      to bottom,
      rgba(101, 146, 190, 0.95) 0%,
      rgba(84, 130, 174, 0.95) 100%
    );
  }

  /* ── Mobile overrides ─────────────────────────────────────────────────────
     The whole layout is scaled down via transform in BaseLayout.
     These values are in the *unscaled* coordinate space, the browser scales
     them along with everything else.

     Logo: left: -90px sits at -255px in layout coords (header is at -165px).
     Setting left: 110px brings the logo onto screen after scaling.

     Heights doubled so they appear the same relative size after scaling.
  ───────────────────────────────────────────────────────────────────────── */
  @media (max-width: 1020px) {
    .header,
    .subheader {
      width: 100%;
      left: 0;
    }

    /* Right panel is hidden via .no-mobile, so center auto-fills the freed
       space. Extend leftward (width: 110%, all offset on the left side) so
       the left panel pokes past the header on mobile. */
    .main-row {
      width: 102%;
      left: -2%;
      min-height: 150vh;
    }

    .panel-left {
      flex: 0 0 30%;
    }

    .logo-wrap {
      left: -55px;
    }

    .subheader:not(.stamps) {
      height: 60px;
    }

    .stamps {
      height: 120px;
    }

    .marquee {
      height: 120px;
    }

    .marquee__inner img {
      height: 104px;
    }

    .welcome-scroll span {
      font-size: 28px;
    }
  }
</style>
