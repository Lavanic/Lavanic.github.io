---
const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <!-- Browser chrome color: works on Android Chrome + iOS Safari 15+ for address bar -->
    <meta name="theme-color" content="#29303C" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
    <title>{title}</title>
    <link rel="preload" as="image" href="/images/logo_fallback.png" />
    <link rel="preload" as="image" href="/images/static.png" />
    <link rel="preload" as="image" href="/images/gears.webp" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --gap: 10px;
    --container-width: 960px;
    --border-inner: rgb(13, 25, 136);
    --border-outer: rgb(96, 96, 96);
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html, body {
    height: 100%;
    overflow-x: hidden;
  }

  body {
    position: relative;
    display: flex;
    justify-content: center;
    padding: 20px;
    background-color: #29303C;
  }

  body::before {
    content: "";
    position: fixed;
    inset: 0;
    background-image: url("/images/background.png");
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    opacity: 1.0;
    z-index: -1;
  }

  .layout {
    width: var(--container-width);
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: var(--gap);
  }

  .box {
    box-shadow:
      0 0 0 1.5px var(--border-inner),
      0 0 0 3px var(--border-outer);
    background: white;
  }

  /* Utility: add `no-mobile` to any element to hide it once the layout hits
     its first scale-down breakpoint. Will be used for arm lol */
  @media (max-width: 1020px) {
    .no-mobile { display: none !important; }
  }

  /* ── Mobile scaling ──────────────────────────────────────────────────────
     The site is fixed-width (960px). Rather than rebuilding the layout,
     we scale the whole thing down like zooming out
  ───────────────────────────────────────────────────────────────────────── */
  @media (max-width: 1020px) {
    .layout {
      transform: scale(0.9);
      transform-origin: top center;
      margin-bottom: -10%;
    }
  }

  @media (max-width: 900px) {
    .layout {
      transform: scale(0.78);
      transform-origin: top center;
      margin-bottom: -22%;
    }
  }

  @media (max-width: 780px) {
    .layout {
      transform: scale(0.67);
      transform-origin: top center;
      margin-bottom: -33%;
    }
  }

  @media (max-width: 650px) {
    .layout {
      transform: scale(0.56);
      transform-origin: top center;
      margin-bottom: -44%;
    }
  }

  @media (max-width: 540px) {
    .layout {
      transform: scale(0.46);
      transform-origin: top center;
      margin-bottom: -54%;
    }
  }

  @media (max-width: 430px) {
    .layout {
      transform: scale(0.37);
      transform-origin: top center;
      margin-bottom: -63%;
    }
  }

  @media (max-width: 360px) {
    .layout {
      transform: scale(0.31);
      transform-origin: top center;
      margin-bottom: -69%;
    }
  }
</style>